<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="176dp"
    android:background="?attr/colorPrimary" android:gravity="bottom"
    android:orientation="vertical" android:padding="16dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">
    <ImageView android:layout_width="64dp" android:layout_height="64dp"
        android:src="@drawable/ic_inventory" app:tint="@android:color/white" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="12dp" android:text="QR Inventaris"
        android:textColor="@android:color/white" android:textSize="16sp" android:textStyle="bold" />
    <TextView android:id="@+id/tvUserInfo" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Pengguna"
        android:textColor="#B3FFFFFF" android:textSize="12sp" />
</LinearLayout>
