<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
            android:layout_width="0dp" android:layout_height="?attr/actionBarSize" android:background="?attr/colorPrimary"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" app:title="Pengaturan" app:titleTextColor="@android:color/white" />

        <!-- User Info Card -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardUser"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_margin="16dp"
            app:cardCornerRadius="12dp" app:contentPadding="16dp"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbar">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvUserInfo" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/text_primary" android:textSize="15sp"
                    app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                <TextView android:id="@+id/tvUserLevel" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" android:textColor="@color/text_secondary" android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/tvUserInfo" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- API URL Card -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardApi"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" app:cardCornerRadius="12dp" app:contentPadding="16dp"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardUser">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvApiTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Server API"
                    android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilApiUrl"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"
                    android:hint="API Base URL" app:layout_constraintTop_toBottomOf="@+id/tvApiTitle">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etApiUrl"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveApi"
                    android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp"
                    android:text="Simpan URL API" app:layout_constraintTop_toBottomOf="@+id/tilApiUrl" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Config Card -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/cardConfig"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp" android:layout_marginTop="12dp" app:cardCornerRadius="12dp" app:contentPadding="16dp"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardApi"
            android:visibility="gone">
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvConfigTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Konfigurasi Aplikasi"
                    android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilInstansi1"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"
                    android:hint="Instansi Baris 1" app:layout_constraintTop_toBottomOf="@+id/tvConfigTitle">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etInstansi1"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilInstansi2"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="Instansi Baris 2" app:layout_constraintTop_toBottomOf="@+id/tilInstansi1">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etInstansi2"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilSekolah"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="Nama Sekolah/Instansi" app:layout_constraintTop_toBottomOf="@+id/tilInstansi2">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etSekolah"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilAlamat"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="Alamat" app:layout_constraintTop_toBottomOf="@+id/tilSekolah">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etAlamat"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilKontak"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="Kontak" app:layout_constraintTop_toBottomOf="@+id/tilAlamat">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etKontak"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilKota"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="Kota Surat" app:layout_constraintTop_toBottomOf="@+id/tilKontak">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etKota"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilKepsek"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="Nama Kepala Sekolah" app:layout_constraintTop_toBottomOf="@+id/tilKota">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etKepsek"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilNipKepsek"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="NIP Kepala Sekolah" app:layout_constraintTop_toBottomOf="@+id/tilKepsek">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etNipKepsek"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilPetugas"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="Nama Petugas" app:layout_constraintTop_toBottomOf="@+id/tilNipKepsek">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etPetugas"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilNipPetugas"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="NIP Petugas" app:layout_constraintTop_toBottomOf="@+id/tilPetugas">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etNipPetugas"
                        android:layout_width="match_parent" android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilLogoL"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="URL Logo Kiri" app:layout_constraintTop_toBottomOf="@+id/tilNipPetugas">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etLogoL"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout android:id="@+id/tilLogoR"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp"
                    android:hint="URL Logo Kanan" app:layout_constraintTop_toBottomOf="@+id/tilLogoL">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/etLogoR"
                        android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="textUri" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveConfig"
                    android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="12dp"
                    android:text="Simpan Konfigurasi" app:layout_constraintTop_toBottomOf="@+id/tilLogoR" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton android:id="@+id/btnLogout"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_margin="16dp" android:text="LOGOUT"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardConfig" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
