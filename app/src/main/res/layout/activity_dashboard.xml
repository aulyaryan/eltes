<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer" android:layout_width="match_parent" android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="match_parent">
        <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbar"
            android:layout_width="0dp" android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout android:id="@+id/swipe"
            android:layout_width="0dp" android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/toolbar">
            <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
                <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/content"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:visibility="gone">
                    <!-- Total Barang -->
                    <com.google.android.material.card.MaterialCardView android:id="@+id/cardInventaris"
                        android:layout_width="0dp" android:layout_height="120dp" android:clickable="true"
                        android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="@color/card_blue"
                        app:cardCornerRadius="12dp" app:layout_constraintEnd_toStartOf="@+id/cardUsers"
                        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
                            android:layout_height="match_parent" android:padding="16dp">
                            <TextView android:id="@+id/tvTotalInventaris" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0" android:textColor="@android:color/white"
                                android:textSize="36sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Total Barang" android:textColor="@android:color/white" android:textSize="12sp"
                                app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Pengguna / Users -->
                    <com.google.android.material.card.MaterialCardView android:id="@+id/cardUsers"
                        android:layout_width="0dp" android:layout_height="120dp" android:clickable="true"
                        android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="@color/card_green"
                        app:cardCornerRadius="12dp" app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/cardInventaris" app:layout_constraintTop_toTopOf="parent">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
                            android:layout_height="match_parent" android:padding="16dp">
                            <TextView android:id="@+id/tvTotalPengguna" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-" android:textColor="@android:color/white"
                                android:textSize="18sp" android:textStyle="italic"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Pengguna" android:textColor="@android:color/white" android:textSize="12sp"
                                app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Section: Kondisi Aset -->
                    <TextView android:id="@+id/tvSectionKondisi" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Kondisi Aset"
                        android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/cardInventaris" />
                    <!-- Baik -->
                    <com.google.android.material.card.MaterialCardView android:id="@+id/cardBaik"
                        android:layout_width="0dp" android:layout_height="90dp" android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@color/card_green" app:cardCornerRadius="12dp"
                        app:layout_constraintEnd_toStartOf="@+id/cardRusak" app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tvSectionKondisi">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
                            android:layout_height="match_parent" android:padding="12dp">
                            <TextView android:id="@+id/tvTotalBaik" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0" android:textColor="@android:color/white"
                                android:textSize="28sp" android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Baik" android:textColor="@android:color/white" android:textSize="12sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Rusak -->
                    <com.google.android.material.card.MaterialCardView android:id="@+id/cardRusak"
                        android:layout_width="0dp" android:layout_height="90dp" android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@color/card_red" app:cardCornerRadius="12dp"
                        app:layout_constraintEnd_toStartOf="@+id/cardHilang"
                        app:layout_constraintStart_toEndOf="@+id/cardBaik"
                        app:layout_constraintTop_toBottomOf="@+id/tvSectionKondisi">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
                            android:layout_height="match_parent" android:padding="12dp">
                            <TextView android:id="@+id/tvTotalRusak" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0" android:textColor="@android:color/white"
                                android:textSize="28sp" android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Rusak" android:textColor="@android:color/white" android:textSize="12sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Hilang -->
                    <com.google.android.material.card.MaterialCardView android:id="@+id/cardHilang"
                        android:layout_width="0dp" android:layout_height="90dp" android:layout_marginTop="8dp"
                        app:cardBackgroundColor="@color/card_orange" app:cardCornerRadius="12dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/cardRusak"
                        app:layout_constraintTop_toBottomOf="@+id/tvSectionKondisi">
                        <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent"
                            android:layout_height="match_parent" android:padding="12dp">
                            <TextView android:id="@+id/tvTotalHilang" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="0" android:textColor="@android:color/white"
                                android:textSize="28sp" android:textStyle="bold"
                                app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Hilang" android:textColor="@android:color/white" android:textSize="12sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>
                    <!-- Log Aktivitas -->
                    <com.google.android.material.card.MaterialCardView android:id="@+id/cardLogs"
                        android:layout_width="0dp" android:layout_height="80dp" android:layout_marginTop="12dp"
                        android:clickable="true" android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@color/card_teal" app:cardCornerRadius="12dp"
                        app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/cardBaik">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_margin="16dp" android:text="Log Aktivitas" android:textColor="@android:color/white"
                            android:textSize="16sp" android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </ScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.google.android.material.navigation.NavigationView android:id="@+id/navView"
        android:layout_width="wrap_content" android:layout_height="match_parent" android:layout_gravity="start"
        app:headerLayout="@layout/nav_header" app:menu="@menu/nav_menu" />
</androidx.drawerlayout.widget.DrawerLayout>
